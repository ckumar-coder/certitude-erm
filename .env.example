# Copy this file to .env and fill in real values.
# Never commit the real .env file to source control.

# PostgreSQL connection string
# Local/Docker Compose:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grc_db
# Cloud Run + Cloud SQL (Phase 8): connect via the Cloud SQL Auth Proxy's
# unix socket, mounted at /cloudsql/<INSTANCE_CONNECTION_NAME> when the
# Cloud Run service is deployed with --add-cloudsql-instances. This value
# is generated automatically by deploy/setup-gcp.sh and stored in Secret
# Manager -- you shouldn't need to set it by hand for a deployed instance.
#   DATABASE_URL=postgresql://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE

# Port the Express server listens on
PORT=3000

# --- Security policy (G8) ---

# Minutes of inactivity before a session expires and re-authentication is required
SESSION_TIMEOUT_MINUTES=10

# Minutes an account is locked after 5 consecutive failed login attempts
LOCKOUT_MINUTES=30

# Days before a password must be changed (forced rotation)
PASSWORD_MAX_AGE_DAYS=90

# --- Used only by migrate-v1-to-v2.js (upgrading an existing v1 database) ---
COMPANY_NAME=Default Company
COMPANY_CODE=DEF
